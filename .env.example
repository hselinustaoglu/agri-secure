# === Supabase (Free Tier — PostgreSQL + PostGIS) ===
DATABASE_URL=postgresql://postgres.[your-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://[your-ref].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# === Upstash Redis (Free Tier — Serverless Cache) ===
REDIS_URL=redis://default:[your-token]@[your-redis].upstash.io:6379

# === External API Configuration ===
# All free, no API keys needed for most
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
FAOSTAT_BASE_URL=https://fenixservices.fao.org/faostat/api/v1
WFP_API_BASE_URL=https://api.wfp.org/vam-data-bridges/4.0.0
WORLD_BANK_RTFP_URL=https://microdata.worldbank.org/index.php/catalog/4483
FEWS_NET_BASE_URL=https://fews.net/api
HDX_API_BASE_URL=https://data.humdata.org/api/3

# === App Settings ===
APP_ENV=development
DEBUG=false
API_VERSION=v1
APP_NAME=AgriSecure API
LOG_LEVEL=INFO

# === Cache TTL Settings (seconds) ===
CACHE_TTL_WEATHER=3600
CACHE_TTL_PRICES=86400
CACHE_TTL_FOOD_SECURITY=604800

# === ETL Settings ===
TARGET_COUNTRIES=KEN,ETH,NGA
WEATHER_LOCATIONS=-1.286389,36.817223;9.145000,40.489673;9.082000,8.675277

# === Local Development Overrides ===
# Uncomment below to use a local PostgreSQL instead of Supabase (for offline dev / MicroK8s learning)
# DATABASE_URL=postgresql://agrisecure:CHANGE_ME@localhost:5432/agrisecure
# POSTGRES_DB=agrisecure
# POSTGRES_USER=agrisecure
# POSTGRES_PASSWORD=CHANGE_ME
# Uncomment below to use a local Redis instead of Upstash
# REDIS_URL=redis://localhost:6379/0
