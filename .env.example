# Database
# IMPORTANT: Replace CHANGE_ME with a strong unique password before running.
DATABASE_URL=postgresql://agrisecure:CHANGE_ME@localhost:5432/agrisecure
POSTGRES_DB=agrisecure
POSTGRES_USER=agrisecure
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (Hetzner S3-compatible)
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=agrisecure-data
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# API Settings
DEBUG=false
API_VERSION=v1
APP_NAME=AgriSecure API

# ETL Settings
TARGET_COUNTRIES=KEN,ETH,NGA
WEATHER_LOCATIONS=-1.286389,36.817223;9.145000,40.489673;9.082000,8.675277
